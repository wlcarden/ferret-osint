# === OSINT API Keys ===
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git.

# --- Free tier, no key required ---
# SEC EDGAR: No key needed (use User-Agent header)
SEC_EDGAR_USER_AGENT="YourName your@email.com"

# --- Free tier, key required ---
COURTLISTENER_API_KEY=
OPENFEC_API_KEY=
PATENTSVIEW_API_KEY=
OPENCORPORATES_API_KEY=
HUNTER_IO_API_KEY=
NUMVERIFY_API_KEY=
VIRUSTOTAL_API_KEY=

# --- Free tier, limited ---
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=

# --- Social media (requires accounts) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT="osint-agent/0.1"
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# --- Optional paid ---
OSINT_INDUSTRIES_API_KEY=

# === LLM Analysis (pick one — auto-detected by `analyze --run`) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
# For local models (Ollama, LM Studio, vLLM):
# LLM_BASE_URL=http://localhost:11434/v1

# === Infrastructure ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

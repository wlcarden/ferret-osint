# === ferret-osint API Keys ===
# Copy this file to .env and fill in the keys you have.
# NEVER commit .env to git.
#
# Most tools work without any keys. Keys marked [required] will disable
# the tool if missing. Keys marked [optional] enhance results but aren't needed.
# Run `python -m osint_agent status` to see which tools need attention.

# --- Tool API Keys ---
COURTLISTENER_API_KEY=           # [required] courtlistener — free at courtlistener.com/sign-in/
OPENFEC_API_KEY=                 # [required] openfec — free at api.open.fec.gov/developers/
CONGRESS_API_KEY=                # [required] congress — free at api.congress.gov/sign-up
SEC_EDGAR_USER_AGENT="YourName your@email.com"  # [required] edgar — no key, just identify yourself
PATENTSVIEW_API_KEY=             # [optional] patents — enhances results, free at patentsview.org/apis

# --- LLM Analysis (pick one — auto-detected by `analyze --run`) ---
ANTHROPIC_API_KEY=               # Anthropic Claude API
OPENAI_API_KEY=                  # OpenAI API
OPENROUTER_API_KEY=              # OpenRouter (200+ models)
# LLM_BASE_URL=http://localhost:11434/v1  # Local: Ollama, LM Studio, vLLM
